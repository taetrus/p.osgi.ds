<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<?pde version="3.8"?>
<target name="com.kk.pde.ds Target Platform">
	<locations>
		<!-- OSGi Core and Runtime Dependencies -->
		<location includeDependencyDepth="none" includeDependencyScopes="compile" missingManifest="error" type="Maven">
			<dependencies>
				<!-- Eclipse OSGi Framework -->
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.osgi</artifactId>
					<version>3.22.0</version>
					<type>jar</type>
				</dependency>
				<!-- Equinox Console -->
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.equinox.console</artifactId>
					<version>1.4.800</version>
					<type>jar</type>
				</dependency>
				<!-- Felix SCR -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.scr</artifactId>
					<version>2.2.12</version>
					<type>jar</type>
				</dependency>
				<!-- Felix Gogo -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.gogo.runtime</artifactId>
					<version>1.1.6</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.gogo.command</artifactId>
					<version>1.1.2</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.gogo.shell</artifactId>
					<version>1.1.4</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi Service Component -->
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.service.component</artifactId>
					<version>1.5.1</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.util.function</artifactId>
					<version>1.2.0</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.util.promise</artifactId>
					<version>1.3.0</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi DS Annotations -->
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.service.component.annotations</artifactId>
					<version>1.5.1</version>
					<type>jar</type>
				</dependency>
				<!-- Felix WebConsole (4.3.x has fewer dependencies) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.webconsole</artifactId>
					<version>4.3.16</version>
					<type>jar</type>
				</dependency>
				<!-- Felix WebConsole DS Plugin (2.1.0 compatible with javax.servlet) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.webconsole.plugins.ds</artifactId>
					<version>2.1.0</version>
					<type>jar</type>
				</dependency>
				<!-- Felix Inventory (required by DS plugin) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.inventory</artifactId>
					<version>1.1.0</version>
					<type>jar</type>
				</dependency>
				<!-- Felix HTTP Jetty (4.x compatible with WebConsole 4.x) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.http.jetty</artifactId>
					<version>4.2.26</version>
					<type>jar</type>
				</dependency>
				<!-- Servlet API -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.http.servlet-api</artifactId>
					<version>1.2.0</version>
					<type>jar</type>
				</dependency>
				<!-- Commons FileUpload (WebConsole dependency) -->
				<dependency>
					<groupId>commons-fileupload</groupId>
					<artifactId>commons-fileupload</artifactId>
					<version>1.5</version>
					<type>jar</type>
				</dependency>
				<!-- Commons IO (FileUpload dependency) -->
				<dependency>
					<groupId>commons-io</groupId>
					<artifactId>commons-io</artifactId>
					<version>2.16.1</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi Configuration Admin -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.configadmin</artifactId>
					<version>1.9.26</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi Metatype (for configuration metadata) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.metatype</artifactId>
					<version>1.2.4</version>
					<type>jar</type>
				</dependency>
				<!-- Felix File Install (auto-load configurations) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.fileinstall</artifactId>
					<version>3.7.4</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi Event Admin (required by Health Check) -->
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.service.event</artifactId>
					<version>1.4.1</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.eventadmin</artifactId>
					<version>1.6.4</version>
					<type>jar</type>
				</dependency>
				<!-- Felix Health Check (javax.servlet compatible versions) -->
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.healthcheck.api</artifactId>
					<version>2.0.4</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.healthcheck.core</artifactId>
					<version>2.0.8</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.healthcheck.generalchecks</artifactId>
					<version>2.0.6</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.felix</groupId>
					<artifactId>org.apache.felix.healthcheck.webconsoleplugin</artifactId>
					<version>2.0.2</version>
					<type>jar</type>
				</dependency>
			</dependencies>
		</location>
		<!-- Logging -->
		<location includeDependencyDepth="infinite" includeDependencyScopes="compile" missingManifest="generate" type="Maven">
			<dependencies>
				<dependency>
					<groupId>ch.qos.logback</groupId>
					<artifactId>logback-classic</artifactId>
					<version>1.2.11</version>
					<type>jar</type>
				</dependency>
			</dependencies>
		</location>
		<!-- Eclipse Communication Framework (ECF) — OSGi Remote Services (RSA) -->
		<!-- ECF 3.14.x line: last release with JavaSE-1.8 BREEs (resolves on the Java 21 runtime). -->
		<location includeDependencyDepth="none" includeDependencyScopes="compile" missingManifest="error" type="Maven">
			<dependencies>
				<!-- ECF core + identity -->
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf</artifactId>
					<version>3.10.0</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.identity</artifactId>
					<version>3.9.402</version>
					<type>jar</type>
				</dependency>
				<!-- ECF remote service API + discovery -->
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.remoteservice</artifactId>
					<version>8.14.0</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.remoteservice.asyncproxy</artifactId>
					<version>2.1.200</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.discovery</artifactId>
					<version>5.1.1</version>
					<type>jar</type>
				</dependency>
				<!-- ECF Generic provider transport -->
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.sharedobject</artifactId>
					<version>2.6.200</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.provider</artifactId>
					<version>4.9.1</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.provider.remoteservice</artifactId>
					<version>4.6.1</version>
					<type>jar</type>
				</dependency>
				<!-- ECF Remote Service Admin (RSA) implementation + topology manager -->
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.osgi.services.remoteserviceadmin</artifactId>
					<version>4.9.1</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.osgi.services.remoteserviceadmin.proxy</artifactId>
					<version>1.0.101</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.ecf</groupId>
					<artifactId>org.eclipse.ecf.osgi.services.distribution</artifactId>
					<version>2.1.600</version>
					<type>jar</type>
				</dependency>
				<!-- OSGi Remote Service Admin API package (org.osgi.service.remoteserviceadmin[.namespace]) -->
				<dependency>
					<groupId>org.osgi</groupId>
					<artifactId>org.osgi.service.remoteserviceadmin</artifactId>
					<version>1.1.0</version>
					<type>jar</type>
				</dependency>
				<!-- Equinox bundles required by ECF (Require-Bundle / Import-Package) -->
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.equinox.common</artifactId>
					<version>3.20.100</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.equinox.registry</artifactId>
					<version>3.12.400</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.equinox.concurrent</artifactId>
					<version>1.3.300</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.eclipse.platform</groupId>
					<artifactId>org.eclipse.core.jobs</artifactId>
					<version>3.15.600</version>
					<type>jar</type>
				</dependency>
			</dependencies>
		</location>
		<!-- Document text extraction for RAG. Apache PDFBox 2.0.x handles PDF; it is a
		     self-contained OSGi bundle pair (pdfbox + fontbox) that logs via commons-logging
		     (JCL), NOT slf4j — so it does not disturb the project's slf4j 1.7 / Logback 1.2
		     stack. Office (.docx/.pptx) and .html/.txt are extracted directly in our bundle
		     (OOXML is zipped XML), needing no further libraries. -->
		<location includeDependencyDepth="none" includeDependencyScopes="compile" missingManifest="error" type="Maven">
			<dependencies>
				<dependency>
					<groupId>org.apache.pdfbox</groupId>
					<artifactId>pdfbox</artifactId>
					<version>2.0.32</version>
					<type>jar</type>
				</dependency>
				<dependency>
					<groupId>org.apache.pdfbox</groupId>
					<artifactId>fontbox</artifactId>
					<version>2.0.32</version>
					<type>jar</type>
				</dependency>
				<!-- commons-logging backend for PDFBox/fontbox (JCL). -->
				<dependency>
					<groupId>commons-logging</groupId>
					<artifactId>commons-logging</artifactId>
					<version>1.3.5</version>
					<type>jar</type>
				</dependency>
			</dependencies>
		</location>
	</locations>
</target>
